{
    email {$ACME_EMAIL:ops@example.com}
}

{$DOMAIN:localhost} {
    encode gzip zstd

    redir / /console/ 308
    redir /console /console/ 308

    handle /healthz {
        reverse_proxy backend:8080
    }

    handle /version {
        reverse_proxy backend:8080
    }

    handle /openapi.json {
        reverse_proxy backend:8080
    }

    handle /docs* {
        reverse_proxy backend:8080
    }

    handle /redoc* {
        reverse_proxy backend:8080
    }

    handle /v1/* {
        reverse_proxy backend:8080
    }

    handle /admin/* {
        reverse_proxy backend:8080
    }

    handle /console/* {
        basic_auth {
            {$ADMIN_UI_USER} {$ADMIN_UI_PASSWORD_HASH}
        }
        uri strip_prefix /console
        reverse_proxy frontend:80
    }

    handle {
        respond "not found" 404
    }
}
