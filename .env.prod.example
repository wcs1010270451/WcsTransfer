# =========================
# 域名与外部访问
# =========================

# 正式域名。Caddy 会基于这个域名申请 HTTPS 证书。
DOMAIN=api.example.com

# 对外公开访问地址。前端构建和后端 CORS 都使用这个值。
PUBLIC_BASE_URL=https://api.example.com

# ACME 证书通知邮箱。
ACME_EMAIL=ops@example.com

# 管理端 Web 基础认证用户名。
ADMIN_UI_USER=admin

# 管理端 Web 基础认证密码的 bcrypt 哈希。
# 生成方式：caddy hash-password --plaintext "你的密码"
# 注意：如果放进 docker compose 的 .env 文件，所有 $ 都要写成 $$
ADMIN_UI_PASSWORD_HASH=$$2a$$14$$replace_with_caddy_bcrypt_hash

# =========================
# PostgreSQL / Redis
# =========================

POSTGRES_DB=wcstransfer
POSTGRES_USER=wcstransfer
POSTGRES_PASSWORD=change-me-postgres

# 自动备份配置
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_PREFIX=wcstransfer

# Redis 当前默认不启用密码时可留空
REDIS_PASSWORD=

# =========================
# 应用基础配置
# =========================

APP_NAME=wcstransfer-gateway
APP_ENV=production
GIN_MODE=release
ENABLE_DOCS=false
ENABLE_ADMIN_DEBUG=false

# 首个管理员用户名。启动时用于 bootstrap。
ADMIN_BOOTSTRAP_USERNAME=admin

# 首个管理员密码。填明文，系统启动时自动 bcrypt 哈希。
ADMIN_BOOTSTRAP_PASSWORD=change-me-admin-password

# 首个管理员显示名。
ADMIN_BOOTSTRAP_DISPLAY_NAME=Platform Admin

# 唯一必须保留的应用级 secret。
# 同时用于租户端 JWT，管理员登录态也会默认复用它。
AUTH_TOKEN_SECRET=change-me-app-secret

# =========================
# 后端连接池与超时
# =========================

DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2
DEPENDENCY_TIMEOUT=3s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=120s
HTTP_SHUTDOWN_TIMEOUT=15s

# =========================
# 对账任务
# =========================

RECONCILIATION_ENABLED=true
RECONCILIATION_INTERVAL=1h
RECONCILIATION_DIFF_THRESHOLD=0.001

# =========================
# Provider 异常告警
# =========================

PROVIDER_ALERT_ENABLED=true
PROVIDER_ALERT_WINDOW=5m
PROVIDER_ALERT_INTERVAL=1m
PROVIDER_ALERT_MIN_REQUESTS=10
PROVIDER_ALERT_429_THRESHOLD=0.2
PROVIDER_ALERT_5XX_THRESHOLD=0.2

# =========================
# 钱包 / 预留金额拦截告警
# =========================

TENANT_WALLET_ALERT_ENABLED=true
TENANT_WALLET_ALERT_WINDOW=5m
TENANT_WALLET_ALERT_INTERVAL=1m
TENANT_WALLET_ALERT_MIN_BLOCKS=5
TENANT_RESERVE_ALERT_MIN_BLOCKS=5

# =========================
# 账单扣费异常告警
# =========================

BILLING_ALERT_ENABLED=true
BILLING_ALERT_WINDOW=10m
BILLING_ALERT_INTERVAL=1m
BILLING_ALERT_MIN_COUNT=1
BILLING_ALERT_MIN_AMOUNT=0.01

# =========================
# 依赖异常告警
# =========================

DEPENDENCY_ALERT_ENABLED=true
DEPENDENCY_ALERT_INTERVAL=1m

# =========================
# Webhook 告警通道
# =========================

ALERT_WEBHOOK_URL=

# generic / wecom / feishu
ALERT_WEBHOOK_PROVIDER=generic
ALERT_WEBHOOK_TIMEOUT=5s

# =========================
# 外部 healthz 监控
# =========================

HEALTHCHECK_URL=http://caddy/healthz
HEALTHCHECK_INTERVAL=30
