POSTGRES_DB=wcstransfer
POSTGRES_USER=wcstransfer
POSTGRES_PASSWORD=wcstransfer

APP_ENV=development
APP_NAME=wcstransfer-gateway
HTTP_PORT=8080
GIN_MODE=debug
ENABLE_DOCS=true
ENABLE_ADMIN_DEBUG=true
AUTH_TOKEN_SECRET=change-me-portal-secret
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisAdminPassword123!
ADMIN_BOOTSTRAP_DISPLAY_NAME=System Admin

DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

DEPENDENCY_TIMEOUT=3s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
CORS_ALLOWED_ORIGINS=http://localhost:3211,http://127.0.0.1:3211
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_PROVIDER=feishu
ALERT_WEBHOOK_TIMEOUT=5s
PROVIDER_ALERT_ENABLED=false
PROVIDER_ALERT_WINDOW=5m
PROVIDER_ALERT_INTERVAL=1m
PROVIDER_ALERT_MIN_REQUESTS=10
PROVIDER_ALERT_429_THRESHOLD=0.2
PROVIDER_ALERT_5XX_THRESHOLD=0.2
TENANT_WALLET_ALERT_ENABLED=false
TENANT_WALLET_ALERT_WINDOW=5m
TENANT_WALLET_ALERT_INTERVAL=1m
TENANT_WALLET_ALERT_MIN_BLOCKS=5
TENANT_RESERVE_ALERT_MIN_BLOCKS=5
BILLING_ALERT_ENABLED=false
BILLING_ALERT_WINDOW=10m
BILLING_ALERT_INTERVAL=1m
BILLING_ALERT_MIN_COUNT=1
BILLING_ALERT_MIN_AMOUNT=0.01
DEPENDENCY_ALERT_ENABLED=false
DEPENDENCY_ALERT_INTERVAL=1m
